# Copy to .env.local. Everything is optional: the screener runs on free
# OpenStreetMap data (Overpass + Nominatim) with no keys at all. Keys below
# add ratings, review text, and registration dates.

# Google Places API (New). ~$200/mo free credit covers testing.
# Enable "Places API (New)" in Google Cloud, create an API key.
# Adds: star ratings, review counts, real review text, listed website URLs.
GOOGLE_PLACES_API_KEY=

# OpenCorporates. Works without a token on a strict rate limit; a free/low-cost
# API token raises it. Adds: business registration year ("listed since 2006").
OPENCORPORATES_API_TOKEN=

# Stripe. Enables real Checkout for the Starter/Unlimited tiers (1-day card
# trial, monthly or yearly). Only the secret key is required - prices are
# created inline. To use dashboard-managed prices instead, set the ids below.
STRIPE_SECRET_KEY=
STRIPE_PRICE_STARTER_MO=
STRIPE_PRICE_STARTER_YR=
STRIPE_PRICE_UNLIMITED_MO=
STRIPE_PRICE_UNLIMITED_YR=

# Optional self-hosted endpoints. Defaults are the public instances; point
# these at your own Overpass / Nominatim for production traffic volumes.
# GOOGLE_PLACES_URL overrides the Places API base (proxy/testing).
OVERPASS_URL=
NOMINATIM_URL=
GOOGLE_PLACES_URL=

# Google API spend controls (defaults shown). A crawl sweeps category batches
# sequentially (1 billable request each) and stops early once it has enough
# no-website leads; snapshots are cached BUSINESSES_CACHE_TTL_MIN minutes and
# forced re-crawls are rate-limited server-side. The daily budgets hard-stop
# billable calls per server instance; cached/OSM data answers past them.
GOOGLE_PLACES_MAX_BATCHES=4
GOOGLE_PLACES_TARGET_LEADS=40
GOOGLE_PLACES_DAILY_BUDGET=250
GOOGLE_ENRICH_DAILY_BUDGET=300
BUSINESSES_CACHE_TTL_MIN=30
