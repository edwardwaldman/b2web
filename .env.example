# Copy to .env.local. Everything is optional: the screener runs on free
# OpenStreetMap data (Overpass + Nominatim) with no keys at all. Keys below
# add ratings, review text, and registration dates.

# Google Places API (New). ~$200/mo free credit covers testing.
# Enable "Places API (New)" in Google Cloud, create an API key.
# Adds: star ratings, review counts, real review text, listed website URLs.
GOOGLE_PLACES_API_KEY=

# OpenCorporates. Works without a token on a strict rate limit; a free/low-cost
# API token raises it. Adds: business registration year ("listed since 2006").
OPENCORPORATES_API_TOKEN=

# Optional self-hosted endpoints. Defaults are the public instances; point
# these at your own Overpass / Nominatim for production traffic volumes.
OVERPASS_URL=
NOMINATIM_URL=
