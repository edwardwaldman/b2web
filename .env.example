# Copy to .env.local. Everything is optional: the screener runs on free
# OpenStreetMap data (Overpass + Nominatim) with no keys at all. Keys below
# add ratings, review text, and registration dates.

# Google Places API (New). ~$200/mo free credit covers testing.
# Enable "Places API (New)" in Google Cloud, create an API key.
# Adds: star ratings, review counts, real review text, listed website URLs.
GOOGLE_PLACES_API_KEY=

# OpenCorporates. Works without a token on a strict rate limit; a free/low-cost
# API token raises it. Adds: business registration year ("listed since 2006").
OPENCORPORATES_API_TOKEN=

# Stripe. Enables real Checkout for the paid tiers (1-day card trial, billed
# weekly or monthly):
#   · Pro   — $25/mo (request any location, we crawl it and notify you)
#   · Ultra — $200/mo (call the API yourself; 2 live crawls/day)
# Only the secret key is required — prices are created inline. To pin
# dashboard-managed prices instead, set the ids below (PLAN is PRO or ULTRA,
# cadence is WK or MO).
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_WK=
STRIPE_PRICE_PRO_MO=
STRIPE_PRICE_ULTRA_WK=
STRIPE_PRICE_ULTRA_MO=

# Ultra tier: how many live crawls an Ultra user may run per day (default 2).
# The Owner (ADMIN_SECRET) is uncapped; Pro/Free never crawl — their requests
# are queued. The global GOOGLE_PLACES_DAILY_BUDGET still caps total spend.
ULTRA_DAILY_CALLS=2

# Admin-only crawl gate. Set ADMIN_SECRET to any strong secret; it becomes
# the admin password. Once set, ONLY requests carrying it (the admin's
# browser) can trigger a billable crawl or refresh — everyone else reads the
# shared cache, and uncached areas they open are queued for the admin with a
# request counter. Leave it unset and the gate is open (anyone can crawl).
ADMIN_SECRET=

# Durable shared cache + request queue (Supabase Postgres). Without this the
# cache lives in each server instance's memory and won't reliably persist for
# everyone across Vercel's instances. Set the SERVICE ROLE key (server-only,
# secret — NOT the anon/publishable key) and create the two tables documented
# in lib/store.ts. NEXT_PUBLIC_SUPABASE_URL is reused for the endpoint.
SUPABASE_SERVICE_ROLE_KEY=

# Email notifications (optional). When a requested area is loaded, everyone
# who asked gets an in-app notification always, and an email too if Resend is
# configured. Get a key at resend.com; set NOTIFY_FROM_EMAIL to a verified
# sender. Without RESEND_API_KEY, email is skipped and in-app still works.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=

# Google AdSense — turns the ad spaces into REAL, paying ad units.
# To go live:
#   1. Get approved at https://adsense.google.com and copy your publisher id
#      (looks like ca-pub-0000000000000000). Set it as NEXT_PUBLIC_ADSENSE_CLIENT.
#      This alone loads the AdSense script site-wide and serves /ads.txt.
#   2. In the AdSense dashboard, create Display ad units and copy each unit's
#      slot id (a ~10-digit number). Set at least NEXT_PUBLIC_ADSENSE_SLOT_INFEED;
#      INFEED2 and SIDEBAR fall back to INFEED when unset.
# Free-tier visitors then see live ads in the in-feed and business-page slots;
# every paid tier is ad-free. Until both the client id AND a slot id are set,
# the neutral placeholder boxes stay (nothing bills, nothing renders live).
# Note: these are NEXT_PUBLIC_ (shipped to the browser) — that's expected for
# AdSense, the publisher/slot ids are not secrets.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_INFEED=
NEXT_PUBLIC_ADSENSE_SLOT_INFEED2=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Optional self-hosted endpoints. Defaults are the public instances; point
# these at your own Overpass / Nominatim for production traffic volumes.
# GOOGLE_PLACES_URL overrides the Places API base (proxy/testing).
OVERPASS_URL=
NOMINATIM_URL=
GOOGLE_PLACES_URL=

# Google API spend controls (defaults shown). A crawl sweeps category batches
# sequentially (1 billable request each) and stops early once it has enough
# no-website leads; snapshots are cached BUSINESSES_CACHE_TTL_MIN minutes and
# forced re-crawls are rate-limited server-side. The daily budgets hard-stop
# billable calls per server instance; cached/OSM data answers past them.
GOOGLE_PLACES_MAX_BATCHES=4
GOOGLE_PLACES_TARGET_LEADS=40
GOOGLE_PLACES_DAILY_BUDGET=250
GOOGLE_ENRICH_DAILY_BUDGET=300
BUSINESSES_CACHE_TTL_MIN=30
